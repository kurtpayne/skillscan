// SkillScan Security — Jenkins Declarative Pipeline
//
// Drop this Jenkinsfile into your repository root (or reference it from a
// Multibranch Pipeline / Pipeline job) to scan AI agent skill files on every
// build.  Results are archived as SARIF and optionally published to the
// Warnings Next Generation plugin.
//
// Required Jenkins plugins:
//   - Pipeline (workflow-aggregator)
//   - Warnings Next Generation (warnings-ng)  [optional, for trend charts]
//
// Required agent: any agent with Python 3.10+ available.

pipeline {
    agent any

    // -----------------------------------------------------------------------
    // Parameters — override at job level or via a parameters block in your
    // own Jenkinsfile that calls this one as a shared library.
    // -----------------------------------------------------------------------
    parameters {
        string(
            name: 'SCAN_PATH',
            defaultValue: '.',
            description: 'Path (relative to workspace root) to scan for skill files.'
        )
        choice(
            name: 'POLICY_PROFILE',
            choices: ['default', 'strict', 'permissive'],
            description: 'Built-in policy profile to apply.'
        )
        string(
            name: 'POLICY_FILE',
            defaultValue: '',
            description: 'Path to a custom policy YAML file (overrides POLICY_PROFILE when set).'
        )
        choice(
            name: 'FAIL_ON',
            choices: ['high', 'medium', 'low', 'never'],
            description: 'Minimum severity that causes the build to fail.'
        )
        choice(
            name: 'RULEPACK_CHANNEL',
            choices: ['stable', 'preview', 'labs'],
            description: 'Rulepack channel: stable (default), preview, or labs.'
        )
        string(
            name: 'SKILLSCAN_VERSION',
            defaultValue: '',
            description: 'Version constraint for skillscan-security (e.g. ">=0.3.1"). Leave blank for latest.'
        )
        string(
            name: 'EXTRA_ARGS',
            defaultValue: '',
            description: 'Additional CLI arguments passed directly to `skillscan scan`.'
        )
        booleanParam(
            name: 'PUBLISH_SARIF',
            defaultValue: true,
            description: 'Archive SARIF as a build artifact and publish via Warnings NG (if installed).'
        )
    }

    environment {
        SARIF_FILE = 'skillscan-results.sarif'
        VENV_DIR   = "${WORKSPACE}/.venv-skillscan"
    }

    stages {
        stage('Setup') {
            steps {
                script {
                    // Create an isolated virtualenv so we do not pollute the
                    // system Python or interfere with other build tools.
                    sh '''
                        python3 -m venv "${VENV_DIR}"
                        "${VENV_DIR}/bin/pip" install --upgrade pip --quiet
                    '''

                    def versionArg = params.SKILLSCAN_VERSION?.trim()
                        ? "\"skillscan-security${params.SKILLSCAN_VERSION}\""
                        : 'skillscan-security'

                    sh """
                        "${VENV_DIR}/bin/pip" install ${versionArg} --quiet
                        "${VENV_DIR}/bin/skillscan" --version
                    """
                }
            }
        }

        stage('Scan') {
            steps {
                script {
                    def policyArg = params.POLICY_FILE?.trim()
                        ? "--policy '${params.POLICY_FILE}'"
                        : "--policy-profile '${params.POLICY_PROFILE}'"

                    def extraArgs = params.EXTRA_ARGS?.trim() ?: ''

                    if (params.PUBLISH_SARIF) {
                        // Run once for SARIF output (used for archiving / Warnings NG)
                        // continue-on-error so we can still archive results on failure
                        def sarifExit = sh(
                            script: """
                                set +e
                                "${VENV_DIR}/bin/skillscan" scan '${params.SCAN_PATH}' \\
                                    ${policyArg} \\
                                    --format sarif \\
                                    --out '${env.SARIF_FILE}' \\
                                    --fail-on '${params.FAIL_ON}' \\
                                    --rulepack-channel '${params.RULEPACK_CHANNEL}' \\
                                    ${extraArgs}
                                echo \$?
                            """,
                            returnStdout: true
                        ).trim().readLines().last().toInteger()

                        // Run again for a human-readable summary in the build log
                        sh """
                            "${VENV_DIR}/bin/skillscan" scan '${params.SCAN_PATH}' \\
                                ${policyArg} \\
                                --format compact \\
                                --fail-on never \\
                                --rulepack-channel '${params.RULEPACK_CHANNEL}' \\
                                --no-auto-intel \\
                                ${extraArgs} || true
                        """

                        // Propagate the original exit code to honour fail-on
                        if (sarifExit != 0) {
                            error("SkillScan returned exit code ${sarifExit} — scan verdict meets the --fail-on=${params.FAIL_ON} threshold.")
                        }
                    } else {
                        // Plain text output only
                        sh """
                            "${VENV_DIR}/bin/skillscan" scan '${params.SCAN_PATH}' \\
                                ${policyArg} \\
                                --format text \\
                                --fail-on '${params.FAIL_ON}' \\
                                --rulepack-channel '${params.RULEPACK_CHANNEL}' \\
                                ${extraArgs}
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if (params.PUBLISH_SARIF && fileExists(env.SARIF_FILE)) {
                    // Archive raw SARIF for download
                    archiveArtifacts artifacts: env.SARIF_FILE, allowEmptyArchive: true

                    // Publish to Warnings Next Generation plugin if available.
                    // The plugin must be installed; if it is not, this step is
                    // silently skipped (the try/catch prevents a pipeline failure).
                    try {
                        recordIssues(
                            tools: [sarif(pattern: env.SARIF_FILE, id: 'skillscan-security', name: 'SkillScan Security')],
                            qualityGates: [[threshold: 1, type: 'TOTAL_HIGH', unstable: false]],
                            enabledForFailure: true
                        )
                    } catch (err) {
                        echo "Warnings NG plugin not available — skipping trend chart publication. Install 'warnings-ng' to enable."
                    }
                }
            }
        }

        cleanup {
            // Remove the virtualenv to keep the workspace tidy
            sh 'rm -rf "${VENV_DIR}"'
        }
    }
}
